# Backend base URL — do NOT include a trailing /api unless your server expects it.
# Examples:
#   ENQUIRY_BASE=https://api.profix.in
#   ENQUIRY_BASE=https://api.yourbackend.com/api   (if /api is part of the host path)

ENQUIRY_BASE=https://api.profixe.in
NEXT_PUBLIC_API_URL=https://api.profixe.in

# Legacy alias (optional — ENQUIRY_BASE is preferred)
# NEXT_PUBLIC_ENQUIRY_BASE=https://api.profixe.in
